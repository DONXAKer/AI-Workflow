# =============================================================================
# Workflow – environment variables
# Copy to .env, fill in values, remove comments from value lines.
# =============================================================================

# Admin user password (set before first run; ignored if admin already exists in DB)
ADMIN_PASSWORD=changeme

# OpenRouter API key – https://openrouter.ai/keys
OPENROUTER_API_KEY=

# YouTrack – https://youtrack.example.com (or https://myteam.youtrack.cloud)
YOUTRACK_URL=
# Profile → Hub → Authentication → Tokens (Permanent token)
YOUTRACK_TOKEN=
# Short project key shown in issue IDs, e.g. CRM in CRM-299
YOUTRACK_PROJECT=

# GitHub
# Settings → Developer settings → Personal access tokens → Tokens (classic)
# Required scopes: repo, workflow
GITHUB_TOKEN=
# Organisation or user name (from github.com/<OWNER>/<REPO>)
GITHUB_OWNER=
# Repository name
GITHUB_REPO=

# Optional: git repo to index for knowledge base
# REPO_URL=git@github.com:myorg/myrepo.git
